{
  "manifest_version": 3,
  "name": "SentinelAI — Phishing Guard",
  "version": "1.0.0",
  "description": "Real-time phishing detection for Gmail. Score overlays on every email, deep analysis on click, URL sandbox, and full Sentinel platform integration.",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:8001/*",
    "https://sentinel-ai-backend.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": [
        "shared/utils.js",
        "shared/api.js",
        "content/gmail_content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "SentinelAI Phishing Guard"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "content/content.css"],
      "matches": ["https://mail.google.com/*"]
    }
  ]
}

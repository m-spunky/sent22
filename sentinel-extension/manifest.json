{
  "manifest_version": 3,
  "name": "SentinelAI — Phishing Guard",
  "version": "1.1.0",
  "description": "Real-time phishing detection for Gmail and Outlook. Score overlays on every email, deep analysis on click, URL sandbox, and full Sentinel platform integration.",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://outlook.cloud.microsoft/*",
    "https://mail.google.com/*",
    "https://outlook.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office.com/*",
    "https://outlook.office365.com/*",
    "http://localhost:8001/*",
    "https://sentinel-ai-backend.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "shared/utils.js",
        "shared/api.js",
        "content/gmail_content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://outlook.cloud.microsoft/*",
        "https://outlook.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*"
      ],
      "js": [
        "shared/utils.js",
        "content/outlook_content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "SentinelAI Phishing Guard"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "content/content.css"
      ],
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*"
      ]
    }
  ]
}